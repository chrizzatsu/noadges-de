<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: 4rem 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .footer-logo:hover { color: var(--text-primary); }

  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--gradient-accent);
    border-radius: var(--radius-sm);
    font-weight: 800;
    font-size: 1.1rem;
    color: #fff;
  }

  .footer-brand p {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-links h4 {
    color: var(--text-primary);
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .footer-links a,
  .footer-links p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .social-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-glow);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 2rem;
  }

  .footer-bottom p {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-legal {
    display: flex;
    gap: 1.5rem;
  }

  .footer-legal a {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-legal a:hover {
    color: var(--accent);
  }

  @media (max-width: 868px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 540px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
