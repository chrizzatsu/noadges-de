  }

  .legal-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-content a:hover {
    color: var(--accent-hover);
  }

  .legal-content ul {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .legal-content li {
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }

  .legal-content strong {
    color: var(--text-primary);
  }
</style>
