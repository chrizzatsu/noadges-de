---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Online-Shop Relaunch',
    category: 'E-Commerce',
    description: 'Kompletter Relaunch eines E-Commerce-Systems mit neuem Design, verbesserter UX und optimierter Performance. Ergebnis: 200% mehr Umsatz.',
    tags: ['Shopify', 'React', 'UI/UX'],
    gradient: 'linear-gradient(135deg, #1a1a2e, #16213e)',
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>',
  },
  {
    title: 'SaaS Dashboard',
    category: 'Web-App',
    description: 'Echtzeit-Analytics-Dashboard fuer ein SaaS-Unternehmen. Interaktive Datenvisualisierung mit komplexen Filtern und Export-Funktionen.',
    tags: ['Next.js', 'TypeScript', 'D3.js'],
    gradient: 'linear-gradient(135deg, #0f2027, #203a43)',
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
  },
  {
    title: 'Corporate Identity',
    category: 'Branding',
    description: 'Entwicklung einer vollstaendigen Markenidentitaet fuer ein Tech-Startup inkl. Logo, Farbschema, Typografie und Brand Guidelines.',
    tags: ['Branding', 'Logo', 'Guidelines'],
    gradient: 'linear-gradient(135deg, #1a0a2e, #2d1b69)',
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#7b61ff" stroke-width="1"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>',
  },
  {
    title: 'Immobilien-Plattform',
    category: 'Web-App',
    description: 'Moderne Plattform fuer Immobiliensuche mit interaktiver Karte, Filtern und Kontaktmanagement fuer Makler und Kunden.',
    tags: ['React', 'Node.js', 'MapBox'],
    gradient: 'linear-gradient(135deg, #0a192f, #112240)',
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
  },
  {
    title: 'Fitness-App Landing Page',
    category: 'Landing Page',
    description: 'High-Converting Landing Page fuer eine Fitness-App mit Animationen, Social Proof und optimiertem Conversion-Funnel.',
    tags: ['Astro', 'Animation', 'Conversion'],
    gradient: 'linear-gradient(135deg, #1b0a00, #3d1a00)',
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ff6b35" stroke-width="1"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
  },
  {
    title: 'Restaurant-Webseite',
    category: 'Website',
    description: 'Elegante Webseite fuer ein Sterne-Restaurant mit Online-Reservierung, Speisekarte und Event-Kalender.',
    tags: ['Design', 'WordPress', 'SEO'],
    gradient: 'linear-gradient(135deg, #1a0a0a, #2d1515)',
    icon: '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ff4757" stroke-width="1"><path d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8zM6 1v3M10 1v3M14 1v3"/></svg>',
  },
];

const categories = ['Alle', ...new Set(projects.map(p => p.category))];
---

<Layout title="Projekte" description="Entdecken Sie unsere erfolgreich umgesetzten Projekte - Webentwicklung, Design, E-Commerce und mehr.">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Portfolio</span>
      <h1>Unsere <span class="gradient-text">Projekte</span></h1>
      <p>Eine Auswahl unserer erfolgreich umgesetzten Projekte. Jedes Projekt erzaehlt eine eigene Erfolgsgeschichte.</p>
    </div>
  </section>

  <!-- Filter -->
  <section class="filter-section">
    <div class="container">
      <div class="filter-bar">
        {categories.map((cat, i) => (
          <button class:list={['filter-btn', { active: i === 0 }]} data-filter={cat}>{cat}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      <div class="projects-grid" id="projectsGrid">
        {projects.map((project) => (
          <div class="project-card animate-in" data-category={project.category}>
            <div class="project-image" style={`background: ${project.gradient};`}>
              <div class="project-placeholder" set:html={project.icon} />
            </div>
            <div class="project-body">
              <span class="project-category">{project.category}</span>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="project-tags">
                {project.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Ihr Projekt koennte das naechste sein</h2>
        <p>Lassen Sie uns gemeinsam Ihr naechstes digitales Projekt zum Erfolg fuehren.</p>
        <a href="/contact" class="btn btn-primary">Projekt besprechen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .filter-section {
    padding: 0 0 1rem;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .filter-btn {
    padding: 0.5rem 1.25rem;
    border-radius: 50px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font);
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .project-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all var(--transition);
  }

  .project-card:hover {
    border-color: rgba(0, 194, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
  }

  .project-card.hidden {
    display: none;
  }

  .project-image {
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-placeholder {
    opacity: 0.5;
  }

  .project-body {
    padding: 1.75rem;
    background: var(--bg-card);
  }

  .project-category {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    margin-bottom: 0.75rem;
  }

  .project-body h3 {
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }

  .project-body p {
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .project-tags span {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.6rem;
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .cta-section { padding: 6rem 0; }
  .cta-box {
    text-align: center;
    padding: 4rem 2rem;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .cta-box::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-box > * { position: relative; }
  .cta-box h2 { margin-bottom: 1rem; }
  .cta-box p { max-width: 500px; margin: 0 auto 2rem; }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const filter = btn.getAttribute('data-filter');

      cards.forEach(card => {
        if (filter === 'Alle' || card.getAttribute('data-category') === filter) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
