---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="noadges - Digitale Loesungen, die bewegen. Webentwicklung, Design und digitale Strategie aus einer Hand.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <span class="section-label animate-in">Digitalagentur</span>
      <h1 class="animate-in">Wir gestalten <span class="gradient-text">digitale Erlebnisse</span>, die begeistern</h1>
      <p class="hero-desc animate-in">Von der Idee bis zum Launch: Wir entwickeln massgeschneiderte Webloesungen, die Ihr Unternehmen nach vorne bringen.</p>
      <div class="hero-actions animate-in">
        <a href="/contact" class="btn btn-primary">Projekt starten
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/projects" class="btn btn-outline">Projekte ansehen</a>
      </div>
      <div class="hero-stats animate-in">
        <div class="stat">
          <strong>50+</strong>
          <span>Projekte</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <strong>98%</strong>
          <span>Zufriedenheit</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <strong>5+</strong>
          <span>Jahre Erfahrung</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Preview -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Was wir tun</span>
        <h2>Unsere Leistungen</h2>
        <p>Wir bieten ein umfassendes Spektrum an digitalen Dienstleistungen, um Ihr Unternehmen erfolgreich zu machen.</p>
      </div>
      <div class="grid-3">
        <div class="card service-card animate-in">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3>Webentwicklung</h3>
          <p>Moderne, performante Webseiten und Web-Apps mit den neuesten Technologien.</p>
        </div>
        <div class="card service-card animate-in">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3>UI/UX Design</h3>
          <p>Durchdachte Designs, die Nutzer begeistern und Conversions steigern.</p>
        </div>
        <div class="card service-card animate-in">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3>Digitale Strategie</h3>
          <p>Datengetriebene Strategien fuer nachhaltiges Wachstum im digitalen Raum.</p>
        </div>
      </div>
      <div class="section-cta">
        <a href="/services" class="btn btn-outline">Alle Leistungen ansehen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Unsere Arbeit</span>
        <h2>Ausgewaehlte Projekte</h2>
        <p>Ein Auszug unserer erfolgreich umgesetzten Projekte.</p>
      </div>
      <div class="projects-grid">
        <a href="/projects" class="project-card project-card-large animate-in">
          <div class="project-image" style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
            <div class="project-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
          </div>
          <div class="project-info">
            <span class="project-tag">E-Commerce</span>
            <h3>Online-Shop Relaunch</h3>
            <p>Kompletter Relaunch eines E-Commerce-Systems mit 200% mehr Umsatz.</p>
          </div>
        </a>
        <a href="/projects" class="project-card animate-in">
          <div class="project-image" style="background: linear-gradient(135deg, #0f2027, #203a43);">
            <div class="project-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5"/></svg>
            </div>
          </div>
          <div class="project-info">
            <span class="project-tag">SaaS</span>
            <h3>Dashboard App</h3>
            <p>Analytics-Dashboard fuer Echtzeit-Datenauswertung.</p>
          </div>
        </a>
        <a href="/projects" class="project-card animate-in">
          <div class="project-image" style="background: linear-gradient(135deg, #1a0a2e, #2d1b69);">
            <div class="project-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#7b61ff" stroke-width="1"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
            </div>
          </div>
          <div class="project-info">
            <span class="project-tag">Branding</span>
            <h3>Corporate Identity</h3>
            <p>Komplettes Branding fuer ein Tech-Startup.</p>
          </div>
        </a>
      </div>
      <div class="section-cta">
        <a href="/projects" class="btn btn-outline">Alle Projekte ansehen
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Workflow -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Unser Prozess</span>
        <h2>So arbeiten wir</h2>
        <p>Ein klarer Prozess fuer ein perfektes Ergebnis.</p>
      </div>
      <div class="grid-4 process-grid">
        <div class="process-step animate-in">
          <div class="process-number">01</div>
          <h3>Analyse</h3>
          <p>Wir verstehen Ihr Geschaeft, Ihre Ziele und Ihre Zielgruppe.</p>
        </div>
        <div class="process-step animate-in">
          <div class="process-number">02</div>
          <h3>Konzept</h3>
          <p>Wir entwickeln eine Strategie und ein Design-Konzept.</p>
        </div>
        <div class="process-step animate-in">
          <div class="process-number">03</div>
          <h3>Umsetzung</h3>
          <p>Wir setzen die Loesung mit modernsten Technologien um.</p>
        </div>
        <div class="process-step animate-in">
          <div class="process-number">04</div>
          <h3>Launch</h3>
          <p>Wir gehen live und optimieren kontinuierlich weiter.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Bereit fuer Ihr naechstes Projekt?</h2>
        <p>Lassen Sie uns gemeinsam etwas Grossartiges schaffen. Kontaktieren Sie uns fuer ein unverbindliches Erstgespraech.</p>
        <a href="/contact" class="btn btn-primary">Jetzt Kontakt aufnehmen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(0, 194, 255, 0.08) 0%, rgba(123, 97, 255, 0.04) 40%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    text-align: center;
    padding: 8rem 0 4rem;
  }

  .hero-desc {
    font-size: 1.2rem;
    max-width: 640px;
    margin: 1.5rem auto 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat strong {
    font-size: 2rem;
    font-weight: 800;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat span {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  /* Service Cards */
  .service-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background: var(--accent-glow);
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .service-card h3 {
    margin-bottom: 0.5rem;
  }

  .section-cta {
    text-align: center;
    margin-top: 3rem;
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.5rem;
  }

  .project-card {
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: all var(--transition);
    color: var(--text-primary);
  }

  .project-card:hover {
    border-color: rgba(0, 194, 255, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
    color: var(--text-primary);
  }

  .project-card-large {
    grid-row: 1 / 3;
  }

  .project-card-large .project-image {
    height: 100%;
    min-height: 300px;
  }

  .project-image {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-placeholder {
    opacity: 0.5;
  }

  .project-info {
    padding: 1.5rem;
    background: var(--bg-card);
  }

  .project-tag {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    margin-bottom: 0.75rem;
  }

  .project-info h3 {
    margin-bottom: 0.5rem;
  }

  .project-info p {
    font-size: 0.95rem;
  }

  /* Process */
  .process-step {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .process-number {
    font-size: 3rem;
    font-weight: 800;
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .process-step h3 {
    margin-bottom: 0.5rem;
  }

  /* CTA */
  .cta-section {
    padding: 6rem 0;
  }

  .cta-box {
    text-align: center;
    padding: 4rem 2rem;
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .cta-box::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-box > * {
    position: relative;
  }

  .cta-box h2 {
    margin-bottom: 1rem;
  }

  .cta-box p {
    max-width: 500px;
    margin: 0 auto 2rem;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .project-card-large {
      grid-row: auto;
    }

    .project-card-large .project-image {
      height: 200px;
      min-height: auto;
    }

    .hero-stats {
      gap: 1.5rem;
    }

    .stat strong {
      font-size: 1.5rem;
    }
  }
</style>
